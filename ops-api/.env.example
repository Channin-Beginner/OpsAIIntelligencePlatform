# MySQL（与 EcomAI 同实例，库名 opsai）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=opsai

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# 本地无密码时留空；若 Redis 配置了 requirepass 则填写对应密码
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# DeepSeek LLM（阶段三 RCA 使用）
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60

# 服务
APP_HOST=127.0.0.1
APP_PORT=8280
APP_VERSION=0.1.0-phase1

# 告警 fingerprint Redis 去重 TTL（秒）
ALERT_FINGERPRINT_TTL_SECONDS=1800

# EcomAI 联动（scripts/chaos 与 scripts/seed 读取，可与 MYSQL_* 同机不同库）
ECOM_MYSQL_HOST=127.0.0.1
ECOM_MYSQL_PORT=3306
ECOM_MYSQL_USER=root
ECOM_MYSQL_PASSWORD=your_password_here
ECOM_MYSQL_DATABASE=ecomai
ECOM_ADMIN_BASE_URL=http://127.0.0.1:8081
ECOM_PORTAL_BASE_URL=http://127.0.0.1:8085
# EcomAI 仓库根目录（用于 inject_llm_timeout / inject_ads_refresh_fail 回退改 .env）
# ECOM_API_REPO_PATH=D:\YIBANWENJIANJI\BIANCHENG\Project\EcomAIIntelligencePlatform
SEED_OUTPUT_DIR=灌注数据
